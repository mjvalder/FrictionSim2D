#!/bin/bash
#SBATCH --nodes={{ nodes }}
#SBATCH --ntasks-per-node={{ ntasks_per_node }}
#SBATCH --cpus-per-task={{ cpus_per_task }}
#SBATCH --time={{ walltime }}
{% if array_size > 1 %}
#SBATCH --array=1-{{ array_size }}
#SBATCH --output={{ log_dir }}/{{ job_name }}_%a_out.txt
#SBATCH --error={{ log_dir }}/{{ job_name }}_%a_err.txt
{% else %}
#SBATCH --output={{ log_dir }}/{{ job_name }}_out.txt
#SBATCH --error={{ log_dir }}/{{ job_name }}_err.txt
{% endif %}
#SBATCH --job-name={{ job_name }}
{% if partition %}
#SBATCH --partition={{ partition }}
{% endif %}
{% if account %}
#SBATCH --account={{ account }}
{% endif %}
{% if mem %}
#SBATCH --mem={{ mem }}
{% endif %}

module purge
{% for mod in modules %}
module load {{ mod }}
{% endfor %}

{% if array_size > 1 %}
TASK_ID=${SLURM_ARRAY_TASK_ID}
{% else %}
TASK_ID=1
{% endif %}

SCRIPT_PATH=$(sed -n "${TASK_ID}p" $SLURM_SUBMIT_DIR/hpc/{{ manifest_filename }})
SCRIPT_DIR=$(dirname "$SCRIPT_PATH")
SIM_PATH=$(dirname "$SCRIPT_DIR")

if [ -z "$SCRIPT_PATH" ]; then
    echo "Error: No script path for index ${TASK_ID}"
    exit 1
fi

{% if use_tmpdir %}
SIM_ROOT=$(basename "$SLURM_SUBMIT_DIR")
SCRATCH={{ scratch_dir }}/${SIM_ROOT}
mkdir -p $SCRATCH/${SIM_PATH}
rsync -av --exclude='*.lammpstrj' --exclude='results/' --exclude='visuals/' --exclude='data/' $SLURM_SUBMIT_DIR/${SIM_PATH}/ $SCRATCH/${SIM_PATH}/
mkdir -p $SCRATCH/${SIM_PATH}/results $SCRATCH/${SIM_PATH}/visuals $SCRATCH/${SIM_PATH}/data
cd $SCRATCH
{% else %}
cd $SLURM_SUBMIT_DIR
{% endif %}

{{ mpi_command }} lmp {{ lmp_flags }} -in ${SCRIPT_PATH}
if [ $? -ne 0 ]; then
    echo "Error: LAMMPS failed on ${SCRIPT_PATH}"
    exit 1
fi

{% if use_tmpdir %}
cp -r ${SIM_PATH}/results ${SIM_PATH}/visuals ${SIM_PATH}/data $SLURM_SUBMIT_DIR/${SIM_PATH}/
{% endif %}

echo "Simulation completed successfully: ${SIM_PATH}"
