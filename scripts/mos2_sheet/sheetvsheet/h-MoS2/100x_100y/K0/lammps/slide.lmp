variable pressure index 1 
label force_loop
variable a index 45 47 49
label angle_loop
# LAMMPS input script

clear

units           metal
atom_style      molecular
boundary   	p p p
neighbor        0.3 bin
neigh_modify    every 1 delay 0 check yes
comm_style       tiled
#------------------Create Geometry------------------------
#----------------- Define the simulation box -------------
region          box block 0.0 101.89012686992 0.0 99.26936804718 -40.0 40.0 units box
create_box      49 box bond/types 1 extra/bond/per/atom 100

read_data       sheetvsheet/h-MoS2/100x_100y/K0/build/h-MoS2_4.lmp extra/bond/per/atom 100 add append group bot

#----------------- Create visualisation files ------------

include sheetvsheet/h-MoS2/100x_100y/K0/lammps/system.in.settings
# Create bonds
bond_style harmonic
bond_coeff 1 5 6.785277671426172 
create_bonds many layer_3 layer_4 1 6.635277671426172 6.935277671426173

dump            sys all atom 1000 ./sheetvsheet/h-MoS2/100x_100y/K0/visuals/$(v_pressure)GPa_$(v_a)angle_1ms.lammpstrj

balance 1.0 rcb
# Minimize the system.
min_style      cg
minimize 1e-4 1e-8 1000000 1000000
##########################################################
#------------------- Apply Constraints ------------------#
##########################################################

#----------------- Apply Langevin thermostat -------------
group center union layer_2 layer_3
velocity        center create 0 492847948
fix             lang center langevin 0 0 $(100.0*dt) 2847563 zero yes

fix             nve_center center nve

timestep        0.001
thermo          1000

fix             fstage_top layer_4 rigid/nve single force * on on on torque * off off off
fix             fsbot layer_1 setforce 0.0 0.0 0.0 
velocity        layer_1 set 0.0 0.0 0.0 units box

compute COM_top layer_4 com
variable comx_top equal c_COM_top[1] 
variable comy_top equal c_COM_top[2] 
variable comz_top equal c_COM_top[3] 

compute COM_ctop layer_3 com
variable comx_ctop equal c_COM_ctop[1] 
variable comy_ctop equal c_COM_ctop[2] 
variable comz_ctop equal c_COM_ctop[3] 

compute COM_cbot layer_2 com
variable comx_cbot equal c_COM_cbot[1] 
variable comy_cbot equal c_COM_cbot[2] 
variable comz_cbot equal c_COM_cbot[3] 

compute COM_bot layer_1 com 
variable comx_bot equal c_COM_bot[1] 
variable comy_bot equal c_COM_bot[2] 
variable comz_bot equal c_COM_bot[3] 

#---------- Apply Uniform Pressure to top layer ----------
# 1 eV/Å^3= 160.2176621 GPa
variable        A          equal (101.89012686992-0.0)*(99.26936804718-0.0)
variable        p          equal v_pressure/160.2176565 # ev/A^3
variable        f          equal -v_p*v_A/(count(layer_4)) # ev/A^2

fix force layer_4 aveforce 0.0 0.0 $f

variable        fx   equal  f_force[1]*1.602176565
variable        fy   equal  f_force[2]*1.602176565
variable        fz   equal  f_force[3]*1.602176565

variable        sx   equal  f_fsbot[1]*1.602176565
variable        sy   equal  f_fsbot[2]*1.602176565
variable        sz   equal  f_fsbot[3]*1.602176565

compute frict layer_3 group/group layer_2
variable xfrict equal c_frict[1]
variable yfrict equal c_frict[2]

run             1000

variable r0_new equal ${comz_top}-${comz_ctop}
bond_coeff 1 5 ${r0_new}
variable virtual_x equal $(v_comx_top)
variable virtual_y equal $(v_comy_top)
variable virtual_z equal $(v_comz_top)+10
create_atoms    49 single $(v_virtual_x) $(v_virtual_y) $(v_virtual_z) units box
group           virtual type 49

velocity        layer_4 set 0.0 0.0 0.0 units box
velocity        virtual set 0.0 0.0 0.0
fix             spr layer_4 spring couple virtual 50 0.0 0.0 NULL 0

variable speed_x equal cos(v_a*PI/180)
variable speed_y equal sin(v_a*PI/180)

fix        move_virtual virtual move linear $(0.1*v_speed_x) $(0.1*v_speed_y) 0.0 

#----------------- Output values -------------------------
fix             fc_ave all ave/time 1 1000 1000 v_xfrict v_yfrict v_sx v_sy v_sz v_fx v_fy v_fz v_comx_ctop v_comy_ctop v_comz_ctop v_comx_cbot v_comy_cbot v_comz_cbot file ./sheetvsheet/h-MoS2/100x_100y/K0/results/fc_ave_slide_$(v_pressure)GPa_$(v_a)angle_1ms

run             50000

if '$(v_a) == 49' then &
'jump SELF pressure_incr'

if '$(v_pressure) == 1' then &
'next a' & 
'clear' & 
'jump SELF angle_loop'

label pressure_incr

next pressure
clear
jump SELF force_loop