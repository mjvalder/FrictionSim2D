variable find index 2 5 10 20 30 50 70 85 100
label force_loop
variable a index 0 2 6 10 14 18 22 26 30 34 38 42 46 50 54 58 62 66 70 74 78 82 86 90 0
label angle_loop
# LAMMPS input script for system build with input of substrate, graphene sheet and AFM tip

clear

units           metal
atom_style      atomic
neighbor        0.3 bin
neigh_modify    every 1 delay 0 check yes #every 5

boundary   	    p p f
read_data       afm/h-MoS2/100x_100y/sub_aSi_tip_Si_r25/K300/l_2/data/load_$(v_find)N.data # Read system data

include         afm/h-MoS2/100x_100y/sub_aSi_tip_Si_r25/K300/l_2/lammps/system.in.settings

#----------------- Create visualisation files ------------

##########################################################
#--------------------Tip Indentation---------------------#
##########################################################
#----------------- Apply constraints ---------------------

fix             sub_fix sub_fix setforce 0.0 0.0 0.0 
fix             tip_f tip_all rigid/nve single force * on on on torque * off off off

#----------------- Apply Langevin thermostat -------------

compute         temp_tip tip_thermo temp/partial 0 1 0
fix             lang_tip tip_thermo langevin 300 300 $(100.0*dt) 699483 zero yes
fix_modify      lang_tip temp temp_tip

compute         temp_base sub_thermo temp/partial 0 1 0
fix             lang_bot sub_thermo langevin 300 300 $(100.0*dt) 2847563 zero yes
fix_modify      lang_bot temp temp_base

fix             nve_all all nve
timestep        0.001
thermo          100

#----------------- Apply pressure to the tip -------------

variable        Ftotal          equal -v_find/1.602176565
variable        Fatom           equal v_Ftotal/count(tip_fix)
fix             forcetip tip_fix aveforce 0.0 0.0 ${Fatom}

##########################################################
#------------------------Compute-------------------------#
##########################################################

compute COM_top layer_2 com
variable comx equal c_COM_top[1] 
variable comy equal c_COM_top[2] 
variable comz equal c_COM_top[3] 

compute COM_tip tip_fix com
variable comx_tip equal c_COM_tip[1] 
variable comy_tip equal c_COM_tip[2] 
variable comz_tip equal c_COM_tip[3] 

#----------------- Calculate total friction --------------

variable        fz_tip   equal  f_forcetip[3]*1.602176565

variable        fx_spr   equal  f_spr[1]*1.602176565

variable        fy_spr   equal f_spr[2]*1.602176565

fix             fc_ave all ave/time 1 1000 1000 v_fz_tip v_fx_spr v_fy_spr v_comx v_comy v_comz v_comx_tip v_comy_tip v_comz_tip file ./afm/h-MoS2/100x_100y/sub_aSi_tip_Si_r25/K300/results/32c_tmpdir/fc_ave_slide_$(v_find)nN_$(v_a)angle_2ms_l2

##########################################################
#---------------------Spring Loading---------------------#
##########################################################

#----------------- Add damping force ---------------------

fix             damp tip_fix viscous 9.986414949216288e-05

variable spring_x equal cos(v_a*PI/180)
variable spring_y equal sin(v_a*PI/180)

#------------------Add lateral harmonic spring------------

fix             spr tip_fix smd cvel 3.12075467163009 0.02 tether $(v_spring_x) $(v_spring_y) NULL 0.0

run 100000

if '$(v_a) == 30' then &
'next a' & 
'jump SELF find_incr'

if '$(v_find) == 30' then &
'next a' & 
'clear' & 
'jump SELF angle_loop'

label find_incr

next find
clear
jump SELF force_loop